{
  "name": "nfc_project_explore",
  "version": "1.0.0",
  "description": "> 让每个人都能在 60 秒内拥有自己的个性化主页。",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "lint:frontend": "cd linkhub-frontend && npm run lint",
    "lint:backend": "cd linkhub-server && npm run lint",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "lint-staged": {
    "linkhub-frontend/src/**/*.{js,jsx}": [
      "cd linkhub-frontend && eslint --fix",
      "prettier --write"
    ],
    "linkhub-server/**/*.js": [
      "cd linkhub-server && eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
