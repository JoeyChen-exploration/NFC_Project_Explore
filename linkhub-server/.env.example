# Server
PORT=3001
NODE_ENV=development

# Security — REQUIRED in production!
# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=your-super-secret-jwt-key-change-me-this-must-be-at-least-32-chars-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Security: Rate limiting (requests per minute per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# (Optional) If migrating to PostgreSQL later:
# DATABASE_URL=postgresql://user:password@localhost:5432/linkhub
